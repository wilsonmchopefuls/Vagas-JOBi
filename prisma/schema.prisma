// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model JobPost {
  id          String   @id @default(cuid())
  type        String   // "vagas" | "freelancers"
  status      String   @default("APPROVED") // "PENDING", "APPROVED", "REJECTED"
  discordId   String
  createdAt   DateTime @default(now())
  payload     String
}

model Admin {
  id        String   @id @default(cuid())
  discordId String   @unique
  addedBy   String?
  createdAt DateTime @default(now())
}

model User {
  discordId String   @id
  name      String
  image     String?
  createdAt DateTime @default(now())
}

// ─── Temas Visuais ──────────────────────────────────────────────────────────

model Theme {
  id        String   @id @default(cuid())
  slot      Int      @unique // 1, 2 ou 3 — máximo 3 temas
  name      String   @db.VarChar(50)
  config    Json     @default("{}") // vars CSS + bgType + bgGifUrl + glows + grid
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPrefs UserThemePreference[]
}

model UserThemePreference {
  userId  String @id  // discordId do usuário
  themeId String
  theme   Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

// ─── Formulário Customizável ──────────────────────────────────────────────────

model FormConfig {
  key       String   @id     // 'job_levels' | 'job_regimes' | 'edu_institutions' | 'edu_courses' | 'edu_levels'
  options   Json     @default("[]")
  updatedAt DateTime @updatedAt
}

// ─── Sistema de Anúncios Centralizado ────────────────────────────────────────

model Ad {
  id        String    @id @default(cuid())
  imageUrl  String    // URL da imagem do criativo
  targetUrl String    // URL de destino ao clicar
  altText   String    @default("Anúncio") // acessibilidade
  active    Boolean   @default(true)
  weight    Int       @default(1)  // peso para rotação: maior = aparece mais
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  clicks    AdClick[]
}

model AdClick {
  id        String   @id @default(cuid())
  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  ip        String?  // hasheado antes de salvar
  createdAt DateTime @default(now())
}
